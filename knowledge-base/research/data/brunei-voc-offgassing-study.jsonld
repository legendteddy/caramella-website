      "mainEntity": [
        {
          "@type": "Question",
          "name": "Does this package contain final measured Brunei results?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "No. It is a protocol and dataset template. Final conclusions require completed field and chamber measurements with validation checks."
          }
        },
        {
          "@type": "Question",
          "name": "Which outcomes are primary in this study?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Primary outcomes are formaldehyde concentration, TVOC concentration, decay behavior over time, and threshold exceedance flags."
          }
        },
        {
          "@type": "Question",
          "name": "Why are edge-sealing details included?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Edge-seal quality can materially influence emissions behavior in humid conditions, so it is recorded as a core explanatory variable."
          }
        }
      ]
