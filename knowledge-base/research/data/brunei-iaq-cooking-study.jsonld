      "mainEntity": [
        {
          "@type": "Question",
          "name": "What is the main endpoint in this study?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "The main endpoints are PM2.5 peak, PM2.5 one-hour mean, NO2 peak, and time-to-baseline after cooking events."
          }
        },
        {
          "@type": "Question",
          "name": "Does this protocol already include measured Brunei household results?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "No. This package is protocol-ready. Conclusions require completion of field data collection and validation steps."
          }
        },
        {
          "@type": "Question",
          "name": "Which interventions are compared?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "The study compares hood use and window and door states, with repeated sessions per home to estimate within-home intervention effects."
          }
        }
      ]
